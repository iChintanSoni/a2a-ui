{
  "name": "a2a-ui",
  "version": "0.8.3",
  "description": "Local-first developer workbench for building, testing, and debugging Agent2Agent (A2A) protocol servers.",
  "keywords": [
    "a2a",
    "agent2agent",
    "agents",
    "nextjs",
    "workbench"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iChintanSoni/a2a-ui.git"
  },
  "bugs": {
    "url": "https://github.com/iChintanSoni/a2a-ui/issues"
  },
  "homepage": "https://github.com/iChintanSoni/a2a-ui#readme",
  "engines": {
    "node": ">=20.9.0"
  },
  "bin": {
    "a2a-ui": "bin/a2a-ui.mjs"
  },
  "files": [
    "app/",
    "bin/",
    "components/",
    "hooks/",
    "lib/",
    "public/",
    "scripts/prepare-standalone.mjs",
    ".next/standalone/",
    "components.json",
    "next.config.ts",
    "postcss.config.mjs",
    "tsconfig.json",
    ".env.example"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build && npm run prepare:standalone",
    "start": "next start",
    "prepare:standalone": "node scripts/prepare-standalone.mjs",
    "prepack": "npm run build",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0",
    "@reduxjs/toolkit": "^2",
    "@tailwindcss/postcss": "^4",
    "class-variance-authority": "^0",
    "clsx": "^2",
    "highlight.js": "^11",
    "idb": "^8",
    "lucide-react": "^1",
    "next": "^16",
    "radix-ui": "^1",
    "react": "^19",
    "react-dom": "^19",
    "react-markdown": "^10",
    "react-redux": "^9",
    "rehype-highlight": "^7",
    "rehype-sanitize": "^6",
    "remark-gfm": "^4",
    "tailwind-merge": "^3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "tw-animate-css": "^1"
  },
  "devDependencies": {
    "@playwright/test": "^1",
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "@testing-library/user-event": "^14",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6",
    "eslint": "^9",
    "eslint-config-next": "^16",
    "happy-dom": "^20",
    "prettier": "^3",
    "prettier-plugin-tailwindcss": "^0",
    "shadcn": "^4",
    "vite-tsconfig-paths": "^6",
    "vitest": "^4"
  }
}
