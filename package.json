{
  "name": "a2a-ui",
  "version": "0.8.4",
  "description": "Local-first developer workbench for building, testing, and debugging Agent2Agent (A2A) protocol servers.",
  "keywords": [
    "a2a",
    "agent2agent",
    "agents",
    "vite",
    "workbench"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iChintanSoni/a2a-ui.git"
  },
  "bugs": {
    "url": "https://github.com/iChintanSoni/a2a-ui/issues"
  },
  "homepage": "https://github.com/iChintanSoni/a2a-ui#readme",
  "type": "module",
  "engines": {
    "node": ">=20.9.0"
  },
  "bin": {
    "a2a-ui": "bin/a2a-ui.mjs"
  },
  "files": [
    "bin/",
    "host/",
    "dist/"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "node host/serve.mjs",
    "prepack": "npm run build",
    "lint": "eslint .",
    "typecheck": "tsc -b --noEmit",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.13",
    "@hono/node-server": "^2.0.4",
    "@reduxjs/toolkit": "^2.12.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "highlight.js": "^11.11.1",
    "hono": "^4.12.23",
    "idb": "^8.0.3",
    "lucide-react": "^1.17.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.3.0",
    "react-router-dom": "^7.16.0",
    "rehype-highlight": "^7.0.2",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.7"
  }
}
