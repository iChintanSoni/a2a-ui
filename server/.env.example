# Demo A2A server
PORT=3001
BASE_URL=http://localhost:3001

# Choose "gemini" or "ollama".
AI_PROVIDER=gemini

# Gemini settings
GEMINI_LLM_MODEL=gemini-2.5-flash
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Optional search tool
TAVILY_API_KEY=

# Ollama settings
OLLAMA_HOST=http://localhost:11434
OLLAMA_LLM_MODEL=qwen3.5:4b
OLLAMA_IMAGE_MODEL=x/flux2-klein:4b
